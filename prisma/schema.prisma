// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ================= ENUMS =================
enum MemberStatus {
  ACTIVE
  BANNED
  PENDING
}

enum AdminRole {
  ADMIN
  SUPER_ADMIN
}

enum AdminStatus {
  ACTIVE
  INACTIVE
}

enum GamePackageStatus {
  ACTIVE
  INACTIVE
}

enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  KBANK
  SCB
  PROMPTPAY
  TRUEMONEY
}

// ================= MODELS =================

model Member {
  memberId  Int          @id @default(autoincrement())
  name      String
  email     String       @unique // ใส่ unique เพื่อใช้ตอน Login 
  password  String
  birthDate DateTime?    @db.Date // ใช้ ? เผื่อลูกค้าไม่กรอก
  createdAt DateTime     @default(now()) @map("created_at")
  isActive  MemberStatus @default(PENDING)
  notes     String?      @db.Text

  orders Order[] // ลูกค้า 1 คน มีได้หลาย Order
}

model Admin {
  adminId   Int         @id @default(autoincrement())
  name      String
  email     String      @unique
  password  String
  role      AdminRole   @default(ADMIN)
  salary    Decimal?    @db.Decimal(10, 2)
  createdAt DateTime    @default(now()) @map("created_at")
  isActive  AdminStatus @default(ACTIVE)
  notes     String?     @db.Text

  approvedOrders Order[] // แอดมิน 1 คน อนุมัติได้หลาย Order
  expenses       Expense[] // แอดมิน 1 คน มีรายการเบิกจ่ายได้หลายรายการ
  transactions   Transaction[] // แอดมิน 1 คน มีรายการการเงินที่ดูแลหลายรายการ

  @@map("Admin")
}

model Game {
  gameId   Int               @id @default(autoincrement())
  gameName String
  uidGame  String?           @map("uid_game")
  category String?
  imageUrl String?           @map("image_url")
  isActive GamePackageStatus @default(ACTIVE)

  packages Package[] // เกม 1 เกม มีได้หลายแพ็กเกจ
}

model Package {
  packageId   Int               @id @default(autoincrement())
  packageName String
  imageUrl    String?
  price       Decimal           @db.Decimal(10, 2)
  unitCost    Decimal           @map("unit_cost") @db.Decimal(10, 2)
  isActive    GamePackageStatus @default(ACTIVE)
  notes       String?           @db.Text

  gameId Int  @map("game_id")
  game   Game @relation(fields: [gameId], references: [gameId])

  orders Order[] // แพ็กเกจ 1 อัน ถูกซื้อได้หลาย Order
}

model Order {
  orderId       Int         @id @default(autoincrement())
  uidGameMember String      @map("uid_game_member") // UID เกมของลูกค้า
  slipImageUrl  String?     @map("slip_image_url")
  amount        Decimal     @db.Decimal(10, 2)
  status        OrderStatus @default(PENDING)
  createdAt     DateTime    @default(now())
  notes         String?     @db.Text

  memberId Int    @map("member_id")
  member   Member @relation(fields: [memberId], references: [memberId])

  packageId Int     @map("package_id")
  package   Package @relation(fields: [packageId], references: [packageId])

  approveBy Int? // ใส่ ? เผื่อกรณี Order เพิ่งสร้าง ยังไม่มีใครอนุมัติ
  admin     Admin? @relation(fields: [approveBy], references: [adminId])

  transactions Transaction[]
}

model Transaction {
  transactionId Int           @id @default(autoincrement())
  amount        Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod @map("payment_method")
  createdAt     DateTime      @default(now()) @map("created_at")

  orderId Int   @map("order_id")
  order   Order @relation(fields: [orderId], references: [orderId])

  adminId Int?   @map("admin_id")
  admin   Admin? @relation(fields: [adminId], references: [adminId])
}

model Expense {
  expenseId Int      @id @default(autoincrement())
  amount    Decimal  @db.Decimal(10, 2)
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  adminId Int   @map("admin_id")
  admin   Admin @relation(fields: [adminId], references: [adminId])
}
