// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Member {
  id          Int      @id @default(autoincrement())
  username    String   @unique
  email       String   @unique
  password    String
  balance     Float    @default(0.0)
  description String?
  role        String   @default("MEMBER") // เพื่อให้เช็คใน Token ง่ายขึ้น
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relationship: ลูกค้า 1 คนมีได้หลาย Order
  orders Order[]
}

// 2. ตารางพนักงาน (แอดมิน)
model AdminStaff {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  email     String   @unique
  password  String
  role      String   @default("STAFF") // เช่น ADMIN, STAFF, SUPERADMIN
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  // Relationship: แอดมินเป็นคนอนุมัติ Order และบันทึกรายจ่าย
  approvedOrders Order[]   @relation("AdminApprover")
  expenses       Expense[]
}

// 3. ตารางเกม
model Game {
  id          Int     @id @default(autoincrement())
  name        String
  image       String? // URL ของรูปภาพเกม
  description String?
  isActive    Boolean @default(true)

  // Relationship: 1 เกม มีหลาย Package
  packages Package[]
}

// 4. ตารางแพ็คเกจเติมเงิน
model Package {
  id        Int    @id @default(autoincrement())
  name      String // เช่น "100 Diamonds"
  price     Float // ราคาขาย
  unit_cost Float // ต้นทุน (เอาไว้คำนวณกำไร)
  gameId    Int
  game      Game   @relation(fields: [gameId], references: [id])

  orders Order[]
}

// 5. ตารางการสั่งซื้อ (หัวใจของระบบ)
model Order {
  id       Int    @id @default(autoincrement())
  memberId Int
  member   Member @relation(fields: [memberId], references: [id])

  packageId Int
  package   Package @relation(fields: [packageId], references: [id])

  amount Float // ยอดเงินรวม
  status String @default("PENDING") // PENDING, COMPLETED, REJECTED

  // เชื่อมกับแอดมินผู้อนุมัติ (อิงตาม ER Diagram ของคุณ)
  approved_by Int?
  admin       AdminStaff? @relation("AdminApprover", fields: [approved_by], references: [id])

  createdAt DateTime @default(now())
}

// 6. ตารางรายจ่าย
model Expense {
  id        Int        @id @default(autoincrement())
  title     String // หัวข้อรายจ่าย เช่น "ค่าเช่า Server"
  amount    Float
  adminId   Int
  admin     AdminStaff @relation(fields: [adminId], references: [id])
  createdAt DateTime   @default(now())
}
